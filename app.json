{
  "expo": {
    "name": "Passando Caso",
    "slug": "passandocaso-app",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "passandocaso",
    "userInterfaceStyle": "automatic",
    "ios": {
      "icon": "./assets/images/icon.png",
      "bundleIdentifier": "com.jrguilherme.passandocasoapp",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false,
      "permissions": [
        "android.permission.RECORD_AUDIO"
      ]
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#0F2D52",
          "image": "./assets/images/icon.png",
          "imageWidth": 150,
          "resizeMode": "contain"
        }
      ],
      [
        "expo-image-picker",
        {
          "cameraPermission": "O PassandoCaso usa a câmera para fotografar o cabeçalho e o prontuário do paciente.",
          "photosPermission": "O PassandoCaso acessa suas fotos para importar imagens de prontuário."
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "e8fd9518-cd72-44e1-b428-777bce0bee42"
      }
    },
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "updates": {
      "url": "https://u.expo.dev/e8fd9518-cd72-44e1-b428-777bce0bee42"
    }
  }
}

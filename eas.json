{
  "cli": {
    "version": ">= 20.1.0",
    "appVersionSource": "remote"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal",
      "channel": "development"
    },
    "preview": {
      "distribution": "internal",
      "channel": "preview"
    },
    "production": {
      "autoIncrement": true,
      "channel": "production",
      "ios": {
        "resourceClass": "m-medium"
      }
    }
  },
  "submit": {
    "production": {
      "ios": {
        "ascAppId": "6782214918"
        // Preencha quando for enviar (evita perguntas interativas no eas submit):
        // "appleId": "seu-apple-id@email.com",   // e-mail da sua conta Apple
        // "appleTeamId": "XXXXXXXXXX"            // Team ID (App Store Connect > Membership)
      }
    }
  }
}
